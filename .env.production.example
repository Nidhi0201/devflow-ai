# Production environment template — set these in Railway / Vercel dashboards

ENVIRONMENT=production
ALLOW_DEMO_LOGIN=false

# GitHub OAuth (one app for your entire deployment)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# OpenAI
OPENAI_API_KEY=

# URLs — replace with your deployed domains
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-api.up.railway.app

# Auth — generate: openssl rand -hex 32
JWT_SECRET=

# Railway auto-injects these when you add plugins:
# DATABASE_URL=postgresql://...
# REDIS_URL=redis://...
