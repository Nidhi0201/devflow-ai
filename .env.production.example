# Production environment template — set on Render (API + worker) and Vercel (frontend)

ENVIRONMENT=production

# GitHub OAuth (one app for your entire deployment)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# OpenAI
OPENAI_API_KEY=

# URLs — set after deploy
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://devflow-api.onrender.com

# Auth — generate: openssl rand -hex 32
JWT_SECRET=

# Render auto-injects when using render.yaml:
# DATABASE_URL=postgresql://...
# REDIS_URL=redis://...
# RENDER_EXTERNAL_URL=https://devflow-api.onrender.com  (API service only)

# Vercel (frontend only):
# NEXT_PUBLIC_API_URL=https://devflow-api.onrender.com
