# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# App URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Auth
JWT_SECRET=change-me-to-a-random-secret-key
ALLOW_DEMO_LOGIN=true

# Database (local dev without Docker — SQLite works out of the box)
DATABASE_URL=sqlite:///./devflow.db
REDIS_URL=redis://localhost:6379/0

# For Docker / production, use PostgreSQL instead:
# DATABASE_URL=postgresql://devflow:devflow@localhost:5432/devflow
